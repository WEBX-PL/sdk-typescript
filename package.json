{
  "name": "@wepeople/sdk",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for the WePeople Ingest API.",
  "license": "MIT",
  "author": "WePeople",
  "homepage": "https://github.com/WEBX-PL/sdk-typescript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WEBX-PL/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/WEBX-PL/sdk-typescript/issues"
  },
  "keywords": [
    "wepeople",
    "sdk",
    "api",
    "typescript",
    "openapi",
    "ingest",
    "observability"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./openapi": "./openapi/v1.yaml",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "openapi",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "openapi-typescript openapi/v1.yaml -o src/generated/openapi.d.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "pnpm generate && pnpm build"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.6.5"
}
